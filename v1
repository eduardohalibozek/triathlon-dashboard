// ── UTILS ─────────────────────────────────────────────────────
function parseDateBR(str) {
  if (!str) return null;

  // Número serial do Google Sheets (ex: 46125)
  if (typeof str === 'number') {
    const utcDays = Math.floor(str) - 25569;
    const d = new Date(utcDays * 86400 * 1000);
    if (isNaN(d)) return null;
    return new Date(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
  }

  // String DD/MM/AAAA
  if (typeof str === 'string') {
    const s = str.trim();
    if (s.includes('/')) {
      const p = s.split('/');
      if (p.length === 3) {
        const d = new Date(parseInt(p[2]), parseInt(p[1])-1, parseInt(p[0]));
        return isNaN(d) ? null : d;
      }
    }
    // ISO AAAA-MM-DD
    if (s.includes('-')) {
      const p = s.split('-');
      if (p.length === 3) {
        const d = new Date(parseInt(p[0]), parseInt(p[1])-1, parseInt(p[2]));
        return isNaN(d) ? null : d;
      }
    }
  }
  return null;
}

function getISOWeek(date) {
  if (!date) return null;
  const d = new Date(date);
  if (isNaN(d)) return null;
  d.setHours(0,0,0,0);
  d.setDate(d.getDate() + 4 - (d.getDay()||7));
  const yearStart = new Date(d.getFullYear(),0,1);
  const week = Math.ceil(((d-yearStart)/86400000+1)/7);
  return `${d.getFullYear()}-S${week.toString().padStart(2,'0')}`;
}

function normalizeTipo(tipo) {
  if (!tipo) return '';
  if (tipo.includes('Corrida') || tipo === 'Run') return 'Corrida';
  if (tipo.includes('Bike') || tipo.includes('Ride')) return 'Bike';
  if (tipo.includes('Natação') || tipo === 'Swim') return 'Natação';
  if (tipo.includes('Academia') || tipo.includes('Musculação') || tipo.includes('Weight') || tipo.includes('Workout')) return 'Academia';
  return tipo;
}

function parsePace(str) {
  if (!str) return 0;
  if (typeof str === 'number') return str;
  const parts = str.toString().split(':');
  if (parts.length === 2) return parseInt(parts[0]) + parseInt(parts[1])/60;
  return parseFloat(str)||0;
}

function formatPace(minPerKm) {
  if (!minPerKm || minPerKm <= 0) return '—';
  const min = Math.floor(minPerKm);
  const sec = Math.round((minPerKm - min)*60);
  return `${min}:${sec.toString().padStart(2,'0')}`;
}

