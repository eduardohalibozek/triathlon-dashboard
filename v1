<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Triathlon Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080810;
  --surface: #101018;
  --surface2: #181826;
  --surface3: #1e1e30;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #eeeef8;
  --muted: rgba(238,238,248,0.38);
  --muted2: rgba(238,238,248,0.6);
  --run: #00e5a0;
  --bike: #4d9fff;
  --swim: #c47dff;
  --gym: #ff9f43;
  --accent: #ff5f3d;
  --up: #00e5a0;
  --down: #ff5f3d;
  --mono: 'DM Mono', monospace;
  --display: 'Syne', sans-serif;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--display);
  min-height: 100vh;
  padding: 28px 32px 48px;
  background-image:
    radial-gradient(ellipse 700px 350px at 90% -5%, rgba(77,159,255,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 500px 300px at 0% 100%, rgba(0,229,160,0.05) 0%, transparent 70%);
}

/* LOADING */
#loading {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 16px; z-index: 999;
  transition: opacity .4s ease;
}
#loading.hidden { opacity: 0; pointer-events: none; }
.spinner {
  width: 36px; height: 36px;
  border: 3px solid var(--surface2);
  border-top-color: var(--run);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-family: var(--mono); font-size: 12px; color: var(--muted); }

/* ERROR */
#error-banner {
  display: none;
  background: rgba(255,95,61,0.1);
  border: 1px solid rgba(255,95,61,0.3);
  border-radius: 12px;
  padding: 14px 20px;
  font-family: var(--mono);
  font-size: 12px;
  color: var(--down);
  margin-bottom: 20px;
}

/* HEADER */
.header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:16px; }
.header-left h1 { font-size:26px; font-weight:800; letter-spacing:-0.5px; line-height:1; }
.header-left p { font-family:var(--mono); font-size:11px; color:var(--muted); margin-top:5px; letter-spacing:.06em; }
.header-right { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }

/* FILTER */
.date-filter { display:flex; align-items:center; gap:8px; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:10px 14px; flex-wrap:wrap; }
.btn-preset { background:var(--surface2); border:1px solid var(--border); border-radius:8px; color:var(--muted2); font-family:var(--mono); font-size:11px; padding:5px 10px; cursor:pointer; transition:all .2s; }
.btn-preset:hover, .btn-preset.active { border-color:var(--run); color:var(--run); }
.btn-refresh { background:var(--surface2); border:1px solid var(--border); border-radius:8px; color:var(--muted2); font-family:var(--mono); font-size:11px; padding:5px 12px; cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:6px; }
.btn-refresh:hover { border-color:var(--bike); color:var(--bike); }
.last-sync { font-family:var(--mono); font-size:10px; color:var(--muted); }

/* COUNTDOWN */
.countdown-bar { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:14px 24px; margin-bottom:20px; display:flex; align-items:center; gap:20px; }
.countdown-label { font-family:var(--mono); font-size:10px; color:var(--muted); letter-spacing:.1em; text-transform:uppercase; white-space:nowrap; }
.countdown-num { font-size:20px; font-weight:800; color:var(--accent); white-space:nowrap; margin-top:2px; }
.countdown-track { flex:1; height:6px; background:var(--surface2); border-radius:99px; overflow:hidden; }
.countdown-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,var(--run),var(--bike)); transition: width .8s ease; }
.countdown-pct { font-family:var(--mono); font-size:12px; color:var(--muted2); white-space:nowrap; }

/* CARDS */
.cards-row { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-bottom:20px; }
.card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:18px; position:relative; overflow:hidden; transition:border-color .2s; animation:fadeUp .35s ease both; }
.card:hover { border-color:var(--border2); }
.card-glow { position:absolute; width:90px; height:90px; border-radius:50%; top:-25px; right:-25px; filter:blur(35px); opacity:.13; }
.card-dot { width:7px; height:7px; border-radius:50%; margin-bottom:10px; }
.card-label { font-family:var(--mono); font-size:10px; color:var(--muted); letter-spacing:.08em; text-transform:uppercase; margin-bottom:6px; }
.card-value { font-size:32px; font-weight:800; line-height:1; letter-spacing:-1px; margin-bottom:8px; }
.card-sub { font-family:var(--mono); font-size:11px; color:var(--muted); }
.meta-ring-wrap { display:flex; align-items:center; gap:10px; margin-top:10px; }
.meta-ring { position:relative; width:36px; height:36px; flex-shrink:0; }
.meta-ring svg { transform:rotate(-90deg); }
.meta-ring-val { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-family:var(--mono); font-size:9px; font-weight:500; }
.meta-text { font-family:var(--mono); font-size:10px; color:var(--muted); line-height:1.5; }
.meta-text strong { color:var(--text); }
.badge { display:inline-flex; align-items:center; gap:3px; font-family:var(--mono); font-size:10px; padding:3px 7px; border-radius:99px; margin-top:6px; }
.badge-up { background:rgba(0,229,160,.1); color:var(--up); }
.badge-down { background:rgba(255,95,61,.1); color:var(--down); }
.badge-neutral { background:rgba(255,255,255,.06); color:var(--muted2); }

/* PANELS */
.panel { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:22px; animation:fadeUp .4s ease both; }
.panel-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:18px; gap:12px; }
.panel-title { font-size:13px; font-weight:700; letter-spacing:-.2px; }
.panel-sub { font-family:var(--mono); font-size:10px; color:var(--muted); margin-top:2px; }
.legend { display:flex; gap:14px; flex-wrap:wrap; }
.legend-item { display:flex; align-items:center; gap:5px; font-family:var(--mono); font-size:10px; color:var(--muted); }
.legend-dot { width:7px; height:7px; border-radius:2px; }

/* LAYOUTS */
.row2  { display:grid; grid-template-columns:2fr 1fr; gap:16px; margin-bottom:20px; }
.row3  { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:20px; }
.row2b { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px; }

/* BAR CHART */
.bar-chart { display:flex; align-items:flex-end; gap:6px; height:130px; }
.bar-group { flex:1; display:flex; flex-direction:column; align-items:center; height:100%; justify-content:flex-end; }
.bar-stack { width:100%; display:flex; flex-direction:column; justify-content:flex-end; gap:2px; flex:1; max-height:100%; }
.bar-seg { width:100%; border-radius:3px 3px 0 0; transition:opacity .2s; min-height:2px; }
.bar-seg:hover { opacity:.75; }
.bar-label { font-family:var(--mono); font-size:9px; color:var(--muted); margin-top:6px; text-align:center; }
.bar-current .bar-label { color:var(--text); }

/* RADAR */
#radar-svg { display:block; margin:0 auto; }

/* ZONES */
.zone-chart { display:flex; flex-direction:column; gap:8px; }
.zone-row { display:flex; align-items:center; gap:8px; }
.zone-name { font-family:var(--mono); font-size:10px; color:var(--muted); width:20px; text-align:right; }
.zone-track { flex:1; height:18px; background:var(--surface2); border-radius:3px; overflow:hidden; }
.zone-fill { height:100%; border-radius:3px; display:flex; align-items:center; padding-left:6px; font-family:var(--mono); font-size:9px; color:rgba(0,0,0,.75); font-weight:500; transition:width .8s ease; }
.zone-pct { font-family:var(--mono); font-size:10px; color:var(--muted); width:32px; text-align:right; }

/* PACE */
.pace-chart { position:relative; height:90px; margin-top:6px; }
.pace-svg { width:100%; height:100%; overflow:visible; }

/* SPORT PROGRESS */
.sport-rows { display:flex; flex-direction:column; gap:12px; }
.sport-row { display:flex; flex-direction:column; gap:5px; }
.sport-row-header { display:flex; justify-content:space-between; align-items:center; }
.sport-name { font-size:12px; font-weight:600; display:flex; align-items:center; gap:5px; }
.sport-dot { width:6px; height:6px; border-radius:50%; }
.sport-val { font-family:var(--mono); font-size:11px; }
.sport-track { height:4px; background:var(--surface2); border-radius:99px; overflow:hidden; }
.sport-fill { height:100%; border-radius:99px; transition:width .8s ease; }
.sport-meta { display:flex; justify-content:space-between; font-family:var(--mono); font-size:9px; color:var(--muted); }

/* VO2 */
.vo2-display { display:flex; align-items:baseline; gap:5px; margin:10px 0 4px; }
.vo2-num { font-size:46px; font-weight:800; letter-spacing:-2px; line-height:1; background:linear-gradient(135deg,var(--run),var(--bike)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.vo2-unit { font-family:var(--mono); font-size:11px; color:var(--muted); }
.vo2-bars { display:flex; gap:4px; align-items:flex-end; height:36px; margin-top:14px; }
.vo2-bar { flex:1; height:100%; border-radius:3px; background:var(--surface2); position:relative; }
.vo2-bar-fill { position:absolute; bottom:0; left:0; right:0; border-radius:3px; transition:height .6s ease; }

/* SWIM */
.swim-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:4px; }
.swim-stat { background:var(--surface2); border-radius:10px; padding:12px; }
.swim-stat-label { font-family:var(--mono); font-size:9px; color:var(--muted); letter-spacing:.06em; text-transform:uppercase; margin-bottom:4px; }
.swim-stat-val { font-size:20px; font-weight:800; letter-spacing:-.5px; color:var(--swim); }
.swim-stat-sub { font-family:var(--mono); font-size:9px; color:var(--muted); margin-top:2px; }
.swim-pace-chart { height:70px; margin-top:12px; }

/* HEATMAP */
.heatmap { display:flex; flex-direction:column; gap:4px; margin-top:4px; }
.heatmap-row { display:flex; gap:4px; align-items:center; }
.heatmap-day-label { font-family:var(--mono); font-size:9px; color:var(--muted); width:24px; }
.heatmap-cell { width:18px; height:18px; border-radius:3px; cursor:pointer; transition:transform .15s; flex-shrink:0; }
.heatmap-cell:hover { transform:scale(1.2); }

/* EMPTY STATE */
.empty { font-family:var(--mono); font-size:12px; color:var(--muted); text-align:center; padding:32px; }

@keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--surface3); border-radius:99px; }
</style>
</head>
<body>

<!-- LOADING -->
<div id="loading">
  <div class="spinner"></div>
  <div class="loading-text">Carregando dados do Strava...</div>
</div>

<!-- ERROR -->
<div id="error-banner"></div>

<!-- HEADER -->
<div class="header">
  <div class="header-left">
    <h1>Triathlon Dashboard</h1>
    <p>SUPER SPRINT · 16 AGO 2026 · <span id="periodo-label">ÚLTIMAS 8 SEMANAS</span></p>
  </div>
  <div class="header-right">
    <div class="date-filter">
      <button class="btn-preset" onclick="setPreset(4,this)">4 sem</button>
