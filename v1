      <div><div class="panel-title">Zonas de FC</div><div class="panel-sub">% tempo · semana atual</div></div>
    </div>
    <div class="zone-chart" id="zone-chart"><div class="empty">carregando...</div></div>
  </div>
</div>

<!-- ROW 3 -->
<div class="row2b">
  <div class="panel">
    <div class="panel-header">
      <div><div class="panel-title">Métricas de natação</div><div class="panel-sub">pace, SWOLF e evolução</div></div>
    </div>
    <div class="swim-grid" id="swim-grid"><div class="empty" style="grid-column:span 2">carregando...</div></div>
    <div class="swim-pace-chart">
      <svg id="swim-pace-svg" width="100%" height="70" viewBox="0 0 400 70" preserveAspectRatio="none"></svg>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:4px">
      <span style="font-family:var(--mono);font-size:9px;color:var(--muted)">evolução pace 100m · semanas</span>
      <span style="font-family:var(--mono);font-size:9px;color:var(--swim)" id="swim-trend"></span>
    </div>
  </div>

  <div class="panel">
    <div class="panel-header">
      <div><div class="panel-title">Resumo geral</div><div class="panel-sub">totais por modalidade</div></div>
    </div>
    <div id="resumo-table"><div class="empty">carregando...</div></div>

    <div style="margin-top:20px">
      <div class="panel-title" style="font-size:12px;margin-bottom:10px">Heatmap de treinos</div>
      <div class="heatmap" id="heatmap"></div>
      <div class="legend" style="margin-top:8px;gap:10px">
        <div class="legend-item"><div class="legend-dot" style="background:var(--run)"></div>Corrida</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--bike)"></div>Bike</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--swim)"></div>Natação</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--gym)"></div>Academia</div>
      </div>
    </div>
  </div>
</div>

<script>
// ── CONFIG ────────────────────────────────────────────────────
const SHEET_ID = '1N5LekpHXEEk__21sqZGNGtbNqsFU9NcyhUNYyw5_K1A';
const METAS    = { Corrida:2, Bike:1, 'Natação':3, 'Academia':3 };
const SPORT_COLOR = { Corrida:'var(--run)', Bike:'var(--bike)', 'Natação':'var(--swim)', 'Academia':'var(--gym)', 'Bike (virtual)':'var(--bike)' };
const PROVA_DATE  = new Date('2026-08-16');
const PREP_START  = new Date('2026-01-01');

let allSemanal   = [];
let allAtividades = [];
let allZonas     = [];
let allResumo    = [];
let visibleN     = 8;

// ── FETCH SHEETS ──────────────────────────────────────────────
async function fetchSheet(aba) {
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(aba)}`;
  const res  = await fetch(url);
  const text = await res.text();
  const json = JSON.parse(text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/)[1]);
  if (!json.table || !json.table.rows) return [];
  const cols = json.table.cols.map(c => c.label);
  return json.table.rows
    .filter(row => row.c && row.c.some(c => c && c.v !== null && c.v !== ''))
    .map(row => {
      const obj = {};
      row.c.forEach((cell, i) => { obj[cols[i]] = cell ? cell.v : null; });
      return obj;
    });
}

// ── LOAD ALL ──────────────────────────────────────────────────
async function loadAll() {
  showLoading(true);
  hideError();
  try {
    const [semanal, atividades, zonas, resumo] = await Promise.all([
      fetchSheet('Semanal'),
      fetchSheet('Atividades'),
      fetchSheet('Zonas FC'),
      fetchSheet('Resumo'),
    ]);
    allSemanal    = semanal;
    allAtividades = atividades;
    allZonas      = zonas;
    allResumo     = resumo;
    document.getElementById('last-sync').textContent =
      'atualizado ' + new Date().toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'});
    renderAll();
  } catch(e) {
    showError('Erro ao carregar dados da planilha. Verifique se ela está pública (Compartilhar → Qualquer pessoa com o link → Leitor).');
    console.error(e);
  }
  showLoading(false);
}

function showLoading(v) {
  const el = document.getElementById('loading');
  el.classList.toggle('hidden', !v);
}
function showError(msg) {
  const el = document.getElementById('error-banner');
  el.style.display = 'block';
  el.textContent   = '⚠ ' + msg;
}
function hideError() {
  document.getElementById('error-banner').style.display = 'none';
}

// ── PRESET FILTER ─────────────────────────────────────────────
function setPreset(n, btn) {
  document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  visibleN = n;
  const label = n === 999 ? 'TODOS OS DADOS' : `ÚLTIMAS ${n} SEMANAS`;
  document.getElementById('periodo-label').textContent = label;
  renderAll();
}

// ── GET VISIBLE WEEKS ─────────────────────────────────────────
function getWeeks() {
  return allSemanal.slice(-Math.min(visibleN, allSemanal.length));
}

// ── COUNTDOWN ─────────────────────────────────────────────────
function renderCountdown() {
  const now        = new Date();
  const msWeek     = 7*24*60*60*1000;
  const weeksLeft  = Math.max(0, Math.ceil((PROVA_DATE - now) / msWeek));
  const totalWeeks = Math.round((PROVA_DATE - PREP_START) / msWeek);
  const doneWeeks  = Math.max(0, totalWeeks - weeksLeft);
  const pct        = Math.min(100, Math.round((doneWeeks / totalWeeks) * 100));
  document.getElementById('countdown-num').textContent   = `${weeksLeft} semanas`;
  document.getElementById('countdown-fill').style.width  = pct + '%';
  document.getElementById('countdown-pct').textContent   = `${pct}% da preparação concluída · prova 16/08/2026`;
}

// ── CARDS ─────────────────────────────────────────────────────
function renderCards() {
  const weeks = getWeeks();
  if (!weeks.length) return;
  const cur  = weeks[weeks.length - 1];
  const prev = weeks[weeks.length - 2] || cur;

  const sports = [
    { key:'Corrida',  acts: cur['Atividades'] ? null : null, km: parseFloat(cur['Corrida km'])||0,   prevKm: parseFloat(prev['Corrida km'])||0 },
    { key:'Bike',     km: parseFloat(cur['Bike km'])||0,     prevKm: parseFloat(prev['Bike km'])||0 },
    { key:'Natação',  km: parseFloat(cur['Natação km'])||0,  prevKm: parseFloat(prev['Natação km'])||0 },
    { key:'Academia', km: null, prevKm: null },
  ];

  // Conta atividades da semana atual e anterior por tipo
  const curSemana  = cur['Semana'];
  const prevSemana = prev['Semana'];

  function countActs(semana, tipo) {
    return allAtividades.filter(a => {
      if (!a['Data'] || !a['Tipo']) return false;
      // tenta bater semana via data
      const d = parseDateBR(a['Data']);
      if (!d) return false;
      return getISOWeek(d) === semana && normalizeTipo(a['Tipo']) === tipo;
    }).length;
  }

  const sportKeys = ['Corrida','Bike','Natação','Academia'];
  const curActs   = {};
  const prevActs  = {};
  sportKeys.forEach(k => {
    curActs[k]  = countActs(curSemana, k);
    prevActs[k] = countActs(prevSemana, k);
  });

  // Fallback: se não conseguiu contar, usa km como proxy
  const container = document.getElementById('cards-row');
  container.innerHTML = '';

  sportKeys.forEach(k => {
    const km     = k === 'Academia' ? null : parseFloat(cur[k === 'Natação' ? 'Natação km' : k === 'Corrida' ? 'Corrida km' : 'Bike km']) || 0;
    const prevKm = k === 'Academia' ? null : parseFloat(prev[k === 'Natação' ? 'Natação km' : k === 'Corrida' ? 'Corrida km' : 'Bike km']) || 0;
    const acts   = curActs[k];
    const pActs  = prevActs[k];
    const meta   = METAS[k] || 1;
    const pct    = Math.min(acts / meta, 1);
    const diff   = acts - pActs;
    const r = 15; const circ = 2*Math.PI*r; const dash = pct*circ;
    const met    = acts >= meta;
    const badgeClass = diff > 0 ? 'badge-up' : diff < 0 ? 'badge-down' : 'badge-neutral';
    const badgeText  = diff > 0 ? `↑ +${diff} vs ant.` : diff < 0 ? `↓ ${diff} vs ant.` : '= igual ant.';
    const color  = SPORT_COLOR[k] || 'var(--muted)';

    container.innerHTML += `
      <div class="card">
        <div class="card-glow" style="background:${color}"></div>
        <div class="card-dot" style="background:${color}"></div>
        <div class="card-label">${k}</div>
        <div class="card-value" style="color:${color}">${acts}</div>
        <div class="card-sub">sessões${km !== null ? ` · ${km.toFixed(1)} km` : ''}</div>
        <div class="badge ${badgeClass}">${badgeText}</div>
        <div class="meta-ring-wrap" style="margin-top:10px">
          <div class="meta-ring">
            <svg width="36" height="36" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="${r}" fill="none" stroke="var(--surface2)" stroke-width="3"/>
              <circle cx="18" cy="18" r="${r}" fill="none" stroke="${met?'var(--up)':color}" stroke-width="3"
                stroke-dasharray="${dash.toFixed(1)} ${circ.toFixed(1)}" stroke-linecap="round"/>
            </svg>
            <div class="meta-ring-val" style="color:${met?'var(--up)':'var(--muted2)'}">${Math.round(pct*100)}%</div>
          </div>
          <div class="meta-text">meta: <strong>${meta}×</strong><br>${met ? '✓ atingida' : `${meta-acts} restante${meta-acts!==1?'s':''}`}</div>
        </div>
      </div>`;
  });

  // Card tempo total
  const totalMin = parseFloat(cur['Tempo Total (h)'])||0;
  const h = Math.floor(totalMin); const m = Math.round((totalMin - h)*60);
  const prevMin = parseFloat(prev['Tempo Total (h)'])||0;
  const tDiff = prevMin > 0 ? ((totalMin-prevMin)/prevMin*100).toFixed(0) : 0;
  const suffer = cur['Suffer Score Total'] || '—';

  container.innerHTML += `
    <div class="card">
      <div class="card-glow" style="background:var(--accent)"></div>
      <div class="card-dot" style="background:var(--accent)"></div>
      <div class="card-label">Tempo total</div>
      <div class="card-value">${h}<span style="font-size:16px;font-weight:400">h</span>${m}<span style="font-size:16px;font-weight:400">m</span></div>
      <div class="card-sub">${cur['Atividades']||0} atividades</div>
      <div class="badge ${parseFloat(tDiff)>=0?'badge-up':'badge-down'}">${parseFloat(tDiff)>=0?'↑ +':'↓ '}${Math.abs(tDiff)}% vs ant.</div>
      <div class="meta-text" style="margin-top:10px;font-family:var(--mono);font-size:10px;color:var(--muted)">
        Suffer score: <span style="color:var(--accent)">${suffer}</span>
      </div>
    </div>`;
}

// ── BAR CHART ─────────────────────────────────────────────────
function renderBars() {
  const weeks  = getWeeks();
  const chart  = document.getElementById('bar-chart');
  chart.innerHTML = '';
  if (!weeks.length) { chart.innerHTML = '<div class="empty">sem dados</div>'; return; }

  const maxTotal = Math.max(...weeks.map(w => (parseFloat(w['Corrida km'])||0) + (parseFloat(w['Bike km'])||0)/5 + (parseFloat(w['Natação km'])||0)*8));

  weeks.forEach((w, i) => {
    const isCurrent = i === weeks.length - 1;
    const runKm  = parseFloat(w['Corrida km'])||0;
    const bikeKm = parseFloat(w['Bike km'])||0;
    const swimKm = parseFloat(w['Natação km'])||0;
    const total  = runKm + bikeKm/5 + swimKm*8;
    const pct    = maxTotal > 0 ? total/maxTotal : 0;
    const swimH  = total > 0 ? (swimKm*8/total)*pct*115 : 0;
    const bikeH  = total > 0 ? (bikeKm/5/total)*pct*115 : 0;
    const runH   = total > 0 ? (runKm/total)*pct*115 : 0;

    const group = document.createElement('div');
    group.className = 'bar-group' + (isCurrent?' bar-current':'');
    group.innerHTML = `
      <div class="bar-stack">
        <div class="bar-seg" style="height:${swimH.toFixed(1)}px;background:var(--swim)"></div>
        <div class="bar-seg" style="height:${bikeH.toFixed(1)}px;background:var(--bike);border-radius:0"></div>
        <div class="bar-seg" style="height:${runH.toFixed(1)}px;background:var(--run);border-radius:0"></div>
      </div>
      <div class="bar-label">${w['Semana']||''}</div>`;
    chart.appendChild(group);
  });

  document.getElementById('bar-legend').innerHTML = [
    ['var(--run)','Corrida'],['var(--bike)','Bike'],['var(--swim)','Natação']
  ].map(([c,l]) => `<div class="legend-item"><div class="legend-dot" style="background:${c}"></div>${l}</div>`).join('');
}

// ── RADAR ─────────────────────────────────────────────────────
function renderRadar() {
  const weeks = getWeeks();
  if (!weeks.length) return;
  const cur = weeks[weeks.length-1];
  const svg = document.getElementById('radar-svg');
  const cx=100,cy=100,r=68;

  // Conta atividades semana atual
  const curSemana = cur['Semana'];
  const labels  = ['Corrida','Bike','Natação','Academia'];
  const metaVals = labels.map(k => METAS[k]||1);
  const curVals  = labels.map(k => {
    return allAtividades.filter(a => {
      const d = parseDateBR(a['Data']);
      return d && getISOWeek(d) === curSemana && normalizeTipo(a['Tipo']) === k;
    }).length;
  });

  const n = labels.length;
  const angle = i => (i/n)*2*Math.PI - Math.PI/2;
  const pt = (val,max,i) => {
    const ratio = Math.min(val/Math.max(max,1),1.15);
    return [cx+r*ratio*Math.cos(angle(i)), cy+r*ratio*Math.sin(angle(i))];
  };

  let html = '';
  [0.25,0.5,0.75,1].forEach(g => {
    const pts = Array.from({length:n},(_,i) => `${cx+r*g*Math.cos(angle(i))},${cy+r*g*Math.sin(angle(i))}`).join(' ');
    html += `<polygon points="${pts}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>`;
  });
  for(let i=0;i<n;i++) {
    html += `<line x1="${cx}" y1="${cy}" x2="${cx+r*Math.cos(angle(i))}" y2="${cy+r*Math.sin(angle(i))}" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>`;
  }
  const metaPts = metaVals.map((v,i) => pt(v,v,i).join(',')).join(' ');
  html += `<polygon points="${metaPts}" fill="rgba(0,229,160,0.08)" stroke="rgba(0,229,160,0.3)" stroke-width="1.5" stroke-dasharray="4 3"/>`;
  const curPts = curVals.map((v,i) => pt(v,metaVals[i],i).join(',')).join(' ');
  html += `<polygon points="${curPts}" fill="rgba(77,159,255,0.18)" stroke="var(--bike)" stroke-width="2"/>`;
  curVals.forEach((v,i) => {
    const [x,y] = pt(v,metaVals[i],i);
    html += `<circle cx="${x}" cy="${y}" r="4" fill="var(--bike)" stroke="var(--bg)" stroke-width="1.5"/>`;
  });
  labels.forEach((label,i) => {
    const lx = cx+(r+18)*Math.cos(angle(i));
    const ly = cy+(r+18)*Math.sin(angle(i));
    const anchor = lx<cx-5?'end':lx>cx+5?'start':'middle';
    html += `<text x="${lx}" y="${ly+4}" text-anchor="${anchor}" fill="rgba(238,238,248,0.45)" font-family="DM Mono,monospace" font-size="9">${label}</text>`;
  });
  svg.innerHTML = html;
}

// ── PROGRESS ──────────────────────────────────────────────────
function renderProgress() {
  const weeks = getWeeks();
  if (weeks.length < 2) return;
  const cur  = weeks[weeks.length-1];
  const prev = weeks[weeks.length-2];
  const container = document.getElementById('progress-rows');
  container.innerHTML = '';

  const sports = [
    { key:'Corrida',  curV: parseFloat(cur['Corrida km'])||0,  prevV: parseFloat(prev['Corrida km'])||0,  unit:'km' },
    { key:'Bike',     curV: parseFloat(cur['Bike km'])||0,     prevV: parseFloat(prev['Bike km'])||0,     unit:'km' },
    { key:'Natação',  curV: parseFloat(cur['Natação km'])||0,  prevV: parseFloat(prev['Natação km'])||0,  unit:'km' },
    { key:'Suffer',   curV: parseFloat(cur['Suffer Score Total'])||0, prevV: parseFloat(prev['Suffer Score Total'])||0, unit:'pts' },
  ];

  sports.forEach(s => {
    const diff = s.prevV > 0 ? ((s.curV-s.prevV)/s.prevV*100).toFixed(0) : 0;
    const up   = parseFloat(diff) >= 0;
    const pct  = Math.min(Math.abs(parseFloat(diff))/50,1)*100;
    const color = s.key === 'Suffer' ? 'var(--accent)' : SPORT_COLOR[s.key]||'var(--muted)';
    container.innerHTML += `
      <div class="sport-row">
        <div class="sport-row-header">
          <span class="sport-name"><span class="sport-dot" style="background:${color}"></span>${s.key}</span>
          <span class="sport-val" style="color:${up?'var(--up)':'var(--down)'}">${up?'+':''}${diff}%</span>
        </div>
        <div class="sport-track"><div class="sport-fill" style="width:${pct}%;background:${up?color:'var(--down)'}"></div></div>
        <div class="sport-meta"><span>${s.curV.toFixed(1)} ${s.unit}</span><span>ant: ${s.prevV.toFixed(1)} ${s.unit}</span></div>
      </div>`;
  });
}

// ── PACE ──────────────────────────────────────────────────────
function renderPace() {
  const weeks = getWeeks();
  // Calcula pace médio por semana a partir de Atividades
  const paceData = weeks.map(w => {
    const sem = w['Semana'];
    const runs = allAtividades.filter(a => {
      const d = parseDateBR(a['Data']);
      return d && getISOWeek(d) === sem && normalizeTipo(a['Tipo']) === 'Corrida' && a['Pace (min/km)'];
    });
    if (!runs.length) return null;
    const paces = runs.map(r => parsePace(r['Pace (min/km)'])).filter(p => p > 0);
    return paces.length ? paces.reduce((a,b)=>a+b,0)/paces.length : null;
  }).filter(p => p !== null);

  if (paceData.length < 2) {
    document.getElementById('pace-svg').innerHTML = '<text fill="rgba(238,238,248,0.3)" x="150" y="45" text-anchor="middle" font-size="11" font-family="DM Mono,monospace">dados insuficientes</text>';
    return;
  }

  const first = paceData[0]; const last = paceData[paceData.length-1];
  const diffSec = Math.round((last - first) * 60);
  const badge = document.getElementById('pace-badge');
  if (diffSec < 0) { badge.className='badge badge-up'; badge.textContent=`↑ −${Math.abs(diffSec)}s/km`; }
  else if (diffSec > 0) { badge.className='badge badge-down'; badge.textContent=`↓ +${diffSec}s/km`; }
  else { badge.textContent=''; }

  const svg = document.getElementById('pace-svg');
  const n   = paceData.length;
  const min = Math.min(...paceData)-0.05; const max = Math.max(...paceData)+0.05;
  const pts = paceData.map((v,i)=>{
    const x=(i/(n-1))*280+10; const y=82-((v-min)/(max-min))*72;
    return `${x},${y}`;
  });
  svg.innerHTML = `
    <defs><linearGradient id="pg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--run)" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="var(--run)" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="M ${pts.join(' L ')} L 290,90 L 10,90 Z" fill="url(#pg)"/>
    <path d="M ${pts.join(' L ')}" fill="none" stroke="var(--run)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    ${paceData.map((v,i)=>{
      const x=(i/(n-1))*280+10; const y=82-((v-min)/(max-min))*72;
      const isCur=i===n-1;
      return `<circle cx="${x}" cy="${y}" r="${isCur?4:2.5}" fill="${isCur?'var(--run)':'var(--bg)'}" stroke="var(--run)" stroke-width="1.5"/>`;
    }).join('')}`;

  const wks = weeks.filter((_,i) => i < paceData.length + (weeks.length - paceData.length));
  document.getElementById('pace-start-label').textContent = weeks[0]?.['Semana']||'';
  document.getElementById('pace-end-label').textContent   = weeks[weeks.length-1]?.['Semana']||'';
}

