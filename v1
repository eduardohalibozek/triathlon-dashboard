// ── SWIM ──────────────────────────────────────────────────────
function renderSwim() {
  const weeks    = getWeeks();
  const curSemana = weeks[weeks.length-1]?.['Semana'];
  const prevSemana = weeks[weeks.length-2]?.['Semana'];

  const swimCur  = allAtividades.filter(a => { const d=parseDateBR(a['Data']); return d && getISOWeek(d)===curSemana  && normalizeTipo(a['Tipo'])==='Natação'; });
  const swimPrev = allAtividades.filter(a => { const d=parseDateBR(a['Data']); return d && getISOWeek(d)===prevSemana && normalizeTipo(a['Tipo'])==='Natação'; });

  // Pace médio 100m (está em Pace min/km, converte: 1km = 10x100m)
  const avgPace = arr => {
    const paces = arr.map(a => parsePace(a['Pace (min/km)'])).filter(p=>p>0);
    return paces.length ? paces.reduce((a,b)=>a+b,0)/paces.length : 0;
  };
  const curPace100  = avgPace(swimCur) / 10;
  const prevPace100 = avgPace(swimPrev) / 10;
  const paceStr     = formatPace(curPace100);
  const paceDiff    = curPace100 > 0 && prevPace100 > 0 ? Math.round((curPace100 - prevPace100)*60) : null;

  const curKm   = swimCur.reduce((s,a)=>s+(parseFloat(a['Distância (km)'])||0),0);
  const ytdKm   = allAtividades.filter(a=>normalizeTipo(a['Tipo'])==='Natação').reduce((s,a)=>s+(parseFloat(a['Distância (km)'])||0),0);

  document.getElementById('swim-grid').innerHTML = [
    { label:'Pace 100m',      val: paceStr||'—',            sub: paceDiff!==null ? (paceDiff<0?`↑ ${Math.abs(paceDiff)}s vs ant.`:`↓ +${paceDiff}s vs ant.`) : '—' },
    { label:'Sessões semana', val: swimCur.length+'×',      sub: `meta: ${METAS['Natação']}× ${swimCur.length>=METAS['Natação']?'✓':''}` },
    { label:'Dist. semana',   val: curKm.toFixed(2)+'km',   sub: '↑ esta semana' },
    { label:'Dist. YTD',      val: ytdKm.toFixed(1)+'km',   sub: 'total acumulado' },
  ].map(s=>`
    <div class="swim-stat">
      <div class="swim-stat-label">${s.label}</div>
      <div class="swim-stat-val">${s.val}</div>
      <div class="swim-stat-sub">${s.sub}</div>
    </div>`).join('');

  // Swim pace line chart por semana
  const swimPaceData = weeks.map(w => {
    const sem  = w['Semana'];
    const rows = allAtividades.filter(a => { const d=parseDateBR(a['Data']); return d && getISOWeek(d)===sem && normalizeTipo(a['Tipo'])==='Natação'; });
    const paces = rows.map(a=>parsePace(a['Pace (min/km)'])/10).filter(p=>p>0);
    return paces.length ? paces.reduce((a,b)=>a+b,0)/paces.length : null;
  });

  const validPaces = swimPaceData.filter(p=>p!==null);
  if (validPaces.length < 2) {
    document.getElementById('swim-pace-svg').innerHTML = '<text fill="rgba(238,238,248,0.3)" x="200" y="35" text-anchor="middle" font-size="11" font-family="DM Mono,monospace">dados insuficientes</text>';
    document.getElementById('swim-trend').textContent = '';
    return;
  }

  const min = Math.min(...validPaces)-0.02; const max = Math.max(...validPaces)+0.02;
  const allPts = swimPaceData.map((v,i)=>v!==null?{x:(i/(swimPaceData.length-1))*380+10,y:62-((v-min)/(max-min))*52}:null);
  const validPts = allPts.filter(p=>p!==null);
  const ptStr = validPts.map(p=>`${p.x},${p.y}`).join(' L ');

  document.getElementById('swim-pace-svg').innerHTML = `
    <defs><linearGradient id="sg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--swim)" stop-opacity="0.2"/>
      <stop offset="100%" stop-color="var(--swim)" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="M ${ptStr} L ${validPts[validPts.length-1].x},70 L ${validPts[0].x},70 Z" fill="url(#sg)"/>
    <path d="M ${ptStr}" fill="none" stroke="var(--swim)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    ${validPts.map((p,i)=>`<circle cx="${p.x}" cy="${p.y}" r="${i===validPts.length-1?4:2}" fill="${i===validPts.length-1?'var(--swim)':'var(--bg)'}" stroke="var(--swim)" stroke-width="1.5"/>`).join('')}`;

  const trend = validPaces[validPaces.length-1] - validPaces[0];
  const trendSec = Math.round(trend * 60);
  document.getElementById('swim-trend').textContent = trendSec < 0 ? `↓ melhorando ${Math.abs(trendSec)}s` : trendSec > 0 ? `↑ desacelerando ${trendSec}s` : '→ estável';
}

