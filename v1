    </div>
    <div class="sport-rows" id="progress-rows"><div class="empty">carregando...</div></div>
  </div>
  <div class="panel">
    <div class="panel-header">
      <div><div class="panel-title">Evolução de pace</div><div class="panel-sub">corrida · min/km</div></div>
      <div class="badge badge-up" id="pace-badge"></div>
    </div>
    <div class="pace-chart">
      <svg class="pace-svg" id="pace-svg" viewBox="0 0 300 90" preserveAspectRatio="none"></svg>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:6px">
      <span style="font-family:var(--mono);font-size:9px;color:var(--muted)" id="pace-start-label"></span>
      <span style="font-family:var(--mono);font-size:9px;color:var(--muted)" id="pace-end-label"></span>
