// ── HEATMAP ───────────────────────────────────────────────────
function renderHeatmap() {
  const dayLabels = ['D','S','T','Q','Q','S','S'];
  const typeColor = { Corrida:'var(--run)', Bike:'var(--bike)', 'Bike (virtual)':'var(--bike)', 'Natação':'var(--swim)', Academia:'var(--gym)' };
  const today = new Date();

  // Mapeia atividades por data
  const byDate = {};
  allAtividades.forEach(a => {
    const d = parseDateBR(a['Data']);
    if (!d) return;
    const key = d.toISOString().split('T')[0];
    byDate[key] = a['Tipo'];
  });

  const container = document.getElementById('heatmap');
  container.innerHTML = '';

  dayLabels.forEach((dl, di) => {
    const row = document.createElement('div');
    row.className = 'heatmap-row';
    row.innerHTML = `<span class="heatmap-day-label">${dl}</span>`;

    for (let w=7; w>=0; w--) {
      const d = new Date(today);
      d.setDate(d.getDate() - (w*7 + (6-di)));
      const key  = d.toISOString().split('T')[0];
      const tipo = byDate[key];
      const tipo_norm = tipo ? normalizeTipo(tipo) : null;
      const color = tipo_norm ? (typeColor[tipo_norm]||'var(--muted2)') : 'var(--surface2)';
      const cell  = document.createElement('div');
      cell.className   = 'heatmap-cell';
      cell.style.background = color;
      cell.style.opacity    = tipo_norm ? '0.8' : '1';
      cell.title = tipo_norm ? `${key} · ${tipo_norm}` : key;
      row.appendChild(cell);
    }
    container.appendChild(row);
  });
}

