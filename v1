<!-- CARDS -->
<div class="cards-row" id="cards-row">
  <div class="card"><div class="empty">carregando...</div></div>
  <div class="card"><div class="empty">carregando...</div></div>
  <div class="card"><div class="empty">carregando...</div></div>
  <div class="card"><div class="empty">carregando...</div></div>
  <div class="card"><div class="empty">carregando...</div></div>
</div>

<!-- ROW 1 -->
<div class="row2">
  <div class="panel">
    <div class="panel-header">
      <div><div class="panel-title">Volume semanal</div><div class="panel-sub">km por modalidade</div></div>
      <div class="legend" id="bar-legend"></div>
    </div>
    <div class="bar-chart" id="bar-chart"><div class="empty">carregando...</div></div>
  </div>
  <div class="panel">
    <div class="panel-header">
      <div><div class="panel-title">Perfil semanal</div><div class="panel-sub">atual vs meta · radar</div></div>
    </div>
    <svg id="radar-svg" width="200" height="200" viewBox="0 0 200 200"></svg>
    <div class="legend" style="justify-content:center;margin-top:10px">
      <div class="legend-item"><div class="legend-dot" style="background:var(--run);opacity:.5"></div>Meta</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--bike)"></div>Atual</div>
